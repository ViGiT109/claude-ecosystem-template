{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autocompleteHistoryLimit": 0,
  "outputStyle": "default",
  "statusLine": {
    "type": "command",
    "command": "python .claude/hooks/_run.py .claude/hooks/statusline.py"
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git tag:*)",
      "Bash(git worktree:*)",
      "Bash(git -C *:*)",
      "Bash(python scripts/*:*)",
      "Bash(python .claude/hooks/*:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/_run.py .claude/hooks/session_start.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/_run.py .claude/hooks/block_no_verify.py",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/_run.py .claude/hooks/planning_hint.py",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "python .claude/hooks/_run.py .claude/hooks/language_check.py",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/_run.py .claude/hooks/stop_audit.py",
            "timeout": 15,
            "async": true
          }
        ]
      }
    ]
  }
}
