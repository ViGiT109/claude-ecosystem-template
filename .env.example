# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.

# Required: GitHub MCP server
GITHUB_PERSONAL_ACCESS_TOKEN=

# Optional: Anthropic SDK (only when calling the API directly — Claude Code CLI handles auth itself)
ANTHROPIC_API_KEY=

# Optional: corporate proxy (uppercase variant is honoured by requests/httpx/curl)
HTTPS_PROXY=

# Optional: set to 1 to silence the planning_hint.py UserPromptSubmit hook
CLAUDE_DISABLE_PLANNING_HINT=

# Add project-specific variables below:
# DATABASE_URL=
# API_KEY=
# OPENAI_API_KEY=
